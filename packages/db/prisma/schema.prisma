  description String?
  updatedAt   DateTime @updatedAt

  @@map("site_config")
}

// ============ LOCATIONS (Districts → Constituencies → Mandals) ============

model District {
  id              String          @id @default(cuid())
  name            String          // Telugu name
  nameEn          String          // English name
  slug            String          @unique
  loksabhaSeats   String?         // Comma-separated Lok Sabha constituency names
  sortOrder       Int             @default(0)
  active          Boolean         @default(true)
  constituencies  Constituency[]
  desk            Desk?           // back-relation: GEOGRAPHIC desk for this district
  createdAt       DateTime        @default(now())

  @@map("districts")
}

/// Assembly Constituency (AC). acNumber = official ECI delimitation number (e.g. 137 = Kurnool).
model Constituency {
  id          String   @id @default(cuid())
  name        String   // Telugu name
  nameEn      String   // English name
  slug        String   @unique
  acNumber    Int?     @unique  // Official ECI AC number (120..175 for Rayalaseema)
  type        String   @default("ASSEMBLY") // ASSEMBLY or LOKSABHA
  districtId  String
  district    District @relation(fields: [districtId], references: [id])
  loksabha    String?  // Which Lok Sabha seat this falls under
  mandals     Mandal[]
  articles    Article[] @relation("ArticleConstituency")
  contents    Content[] @relation("ContentConstituency")
  desk        Desk?     // back-relation: GEOGRAPHIC desk for this AC (e.g. "ప్రొద్దుటూరు")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([districtId])
  @@map("constituencies")
}

// ============ DESKS (byline + e-paper section grouping) ============

enum DeskBranch {
  TOPICAL      // e.g. "రాయలసీమ ఎక్స్‌ప్రెస్ బిజినెస్ డెస్క్" (linked to a Category)
  GEOGRAPHIC   // e.g. "రాయలసీమ ఎక్స్‌ప్రెస్" (root), "అనంతపురం" (district), "ప్రొద్దుటూరు" (AC)
  EDITORIAL    // e.g. "రాయలసీమ ఎక్స్‌ప్రెస్ ఎడిటోరియల్ డెస్క్"
}

/// Desk = byline & section grouping. Hierarchical (Topical/Geographic/Editorial branches).
/// Auto-resolved on article save via fallback chain (see lib/desk-resolver.ts):
///   manual deskId → constituency desk → district desk → category desk → root (Rayalaseema Express)
model Desk {
  id              String        @id @default(cuid())
  name            String        // Telugu display name (the byline string)
  nameEn          String        // English name (admin UI + slug source)
  slug            String        @unique
  branch          DeskBranch
  parentId        String?
  parent          Desk?         @relation("DeskHierarchy", fields: [parentId], references: [id])
  children        Desk[]        @relation("DeskHierarchy")

  // Optional links so we can auto-derive the desk from article metadata.
  // All three are @unique — one desk per category / district / constituency at most.
  categoryId      String?       @unique
  category        Category?     @relation(fields: [categoryId], references: [id])
  districtId      String?       @unique
  district        District?     @relation(fields: [districtId], references: [id])
  constituencyId  String?       @unique
  constituency    Constituency? @relation(fields: [constituencyId], references: [id])

  articles        Article[]
  contents        Content[]
  sortOrder       Int           @default(0)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([branch])
  @@index([parentId])
  @@map("desks")
}

model Mandal {
  id              String       @id @default(cuid())
  name            String       // Telugu name
  nameEn          String       // English name
  slug            String       @unique
  code            Int?         @unique  // Official AP mandal code (e.g. 5259 = Kurnool)
  constituencyId  String
  constituency    Constituency @relation(fields: [constituencyId], references: [id])
  articles        Article[]    @relation("ArticleMandal")
  sortOrder       Int          @default(0)
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([constituencyId])
  @@map("mandals")
}

// ============ VIDEOS ============

model Video {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  thumbnailUrl String
  videoUrl    String?  // YouTube/external URL
