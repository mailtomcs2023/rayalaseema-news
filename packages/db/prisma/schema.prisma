// ============ JOURNALIST PROFILE & KYC ============

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

model JournalistProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal
  fullName        String
  fatherName      String?
  dateOfBirth     DateTime?
  gender          String?
  address         String?   @db.Text
  city            String?
  pincode         String?

  // District assignment
  primaryDistrict String?   // District slug they cover
  secondaryDistricts String[] // Additional districts

  // KYC documents
  kycStatus       KycStatus @default(PENDING)
  aadhaarNumber   String?
  aadhaarFrontUrl String?   // Uploaded image
  aadhaarBackUrl  String?
  panNumber       String?
  panCardUrl      String?
  idCardUrl       String?   // Press/company ID
  photoUrl        String?   // Passport photo

  // Bank / Payment
  upiId           String?
  bankName        String?
  bankAccount     String?
  bankIfsc        String?
  bankBranch      String?

  // Experience
  experience      String?   @db.Text // Previous media experience
  languages       String[]            // ["Telugu", "English", "Hindi"]
  specialization  String?             // "Politics", "Crime", etc.

  // App specific
  deviceToken     String?   // Push notification token
  lastActiveAt    DateTime?

  kycRejectionNote String?
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Reporter-initiated edits awaiting (or completed by) admin review
  profileUpdateRequests ProfileUpdateRequest[]

  @@map("journalist_profiles")
}

// ============ PROFILE UPDATE REQUESTS (reporter -> admin approval) ============

enum ProfileUpdateRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// A single field-level change the reporter wants applied to their profile.
// One PENDING request per (journalistProfileId, field) at a time; re-requesting
// the same field replaces the prior PENDING request.
//
// `oldValue` / `newValue` are stored as text (arrays/dates are JSON-stringified).
// `previousKycStatus` is captured when the request is for a KYC-critical field,
// so we can restore it if admin rejects (we flip the journalist's kycStatus to
// SUBMITTED on submission to pause earnings until re-verification).
model ProfileUpdateRequest {
  id                  String                     @id @default(cuid())
  journalistProfileId String
  journalistProfile   JournalistProfile          @relation(fields: [journalistProfileId], references: [id], onDelete: Cascade)

  field               String                     // e.g. "name", "phone", "aadhaarNumber", "bankIfsc"
  oldValue            String?                    @db.Text
  newValue            String?                    @db.Text

  status              ProfileUpdateRequestStatus @default(PENDING)
  previousKycStatus   KycStatus?                 // restored on REJECT for KYC-critical fields

  reviewerNote        String?                    @db.Text
  reviewedById        String?
  reviewedBy          User?                      @relation("ProfileUpdateRequestReviewer", fields: [reviewedById], references: [id])
  reviewedAt          DateTime?

  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([journalistProfileId, status])
  @@index([status, createdAt])
  @@map("profile_update_requests")
}

// ============ PAYMENT CONFIG (admin-configurable rates) ============

model PaymentConfig {
  id          String   @id @default(cuid())
  articleType String   @unique // "text_news", "photo_news", "video_story", "exclusive", "breaking"
  name        String            // Display name: "Text News (300+ words)"
  nameTE      String?           // Telugu name
  rate        Float             // Base rate in Rs
  minWords    Int     @default(0)  // Minimum word count required
  requiresImage Boolean @default(false)
  requiresVideo Boolean @default(false)
  bonusRate   Float   @default(0) // Bonus per 1000 views
  active      Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments        ArticlePayment[]
  contentPayments ContentPayment[] @relation("ContentPaymentConfig")

  @@map("payment_configs")
}

// ============ ARTICLE PAYMENT ============

enum PaymentStatus {
  CALCULATED  // Auto-calculated when article published
  APPROVED    // Admin approved for payout
  PROCESSING  // Payment being processed
  PAID        // Money transferred
  DISPUTED    // Journalist raised dispute
}

model ArticlePayment {
  id            String        @id @default(cuid())
  articleId     String        @unique
  article       Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  journalistId  String
  journalist    User          @relation(fields: [journalistId], references: [id])
  configId      String?
  config        PaymentConfig? @relation(fields: [configId], references: [id])

  // Payment details
  baseAmount    Float         // Rate from config
  bonusAmount   Float         @default(0)  // View-based bonus
  deductions    Float         @default(0)  // Any deductions
  totalAmount   Float         // Final amount
  currency      String        @default("INR")

  status        PaymentStatus @default(CALCULATED)
  approvedById  String?
  approvedAt    DateTime?
  paidAt        DateTime?
  transactionId String?       // UPI/bank ref number
  paymentMethod String?       // "UPI", "bank_transfer"

  note          String?       // Admin note
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([journalistId, status])
  @@index([status])
  @@map("article_payments")
}

// ============ PAYOUT BATCH ============

model PayoutBatch {
  id            String   @id @default(cuid())
  month         Int      // 1-12
  year          Int
  totalAmount   Float
  totalArticles Int
  totalJournalists Int
  status        String   @default("DRAFT") // DRAFT, APPROVED, PROCESSING, COMPLETED
  approvedById  String?
  approvedAt    DateTime?
  completedAt   DateTime?
  note          String?
  createdAt     DateTime @default(now())

  @@unique([month, year])
  @@map("payout_batches")
}

// ============ UNIFIED CONTENT (Spec #1 — additive, parallel to Article during transition) ============
// See docs/superpowers/specs/2026-05-25-unified-content-model-design.md
//
// One table replaces seven (Article, Video, Reel, WebStory, PhotoGallery,
// Cartoon, BreakingNews). Type discriminated by `type` enum. Type-specific
// fields stored in `payload` JSON column (Zod-validated in app layer).
//
// During Spec #1 implementation this lives ALONGSIDE the legacy tables.
// FK migration on dependent tables happens in #188, table drops in #189.

enum ContentType {
  ARTICLE
  VIDEO
  REEL
  WEB_STORY
  PHOTO_GALLERY
  CARTOON
  BREAKING_NEWS
}

model Content {
  id              String        @id @default(cuid())
  type            ContentType
  title           String
  // Null for BREAKING_NEWS (ticker headline, no public URL). All other types require slug.
  slug            String?       @unique
  summary         String?       @db.Text
  // HTML body — ARTICLE only. Other types render from `payload`.
  body            String?       @db.Text
  featuredImage   String?
  // Type-specific blob. Shape validated by Zod schemas in packages/db/src/payload-schemas.ts.
  payload         Json?

  categoryId      String?
  category        Category?     @relation(fields: [categoryId], references: [id])
  authorId        String
  author          User          @relation("ContentAuthor", fields: [authorId], references: [id])
  deskId          String?
  desk            Desk?         @relation(fields: [deskId], references: [id])
  constituencyId  String?
  constituency    Constituency? @relation("ContentConstituency", fields: [constituencyId], references: [id])

  status          ArticleStatus @default(DRAFT)
  featured        Boolean       @default(false)
  language        Language      @default(TELUGU)
  viewCount       Int           @default(0)

  publishedAt     DateTime?
  scheduledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // PIB approval workflow (preserved from Article — #99)
  needsPibApproval    Boolean       @default(false)
  pibApprovedAt       DateTime?
  pibReferenceNumber  String?

  // Ingestion dedup — source news URL, unique so the same item can't be imported twice
  sourceUrl       String?       @unique

  tags            ContentTag[]
  revisions       ContentRevision[]
  payments        ContentPayment[]

  @@index([type, status, publishedAt])
  @@index([categoryId, status, publishedAt])
  @@index([status, publishedAt])
  @@index([authorId])
  @@index([constituencyId])
  @@index([deskId])
  @@map("contents")
}

model ContentTag {
  contentId  String
  content    Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  tagId      String
  tag        Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contentId, tagId])
  @@map("content_tags")
}

model ContentRevision {
  id              String        @id @default(cuid())
  contentId       String
  content         Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)

  title           String
  slug            String?
  summary         String?       @db.Text
  body            String?       @db.Text
  featuredImage   String?
  categoryId      String?
  payload         Json?
  status          ArticleStatus

  editedById      String
  editedBy        User          @relation(fields: [editedById], references: [id])
  editNote        String?
  bodyLength      Int           @default(0)

  createdAt       DateTime      @default(now())

  @@index([contentId, createdAt])
  @@index([editedById])
  @@map("content_revisions")
}

model ContentPayment {
  id            String         @id @default(cuid())
  contentId     String         @unique
  content       Content        @relation(fields: [contentId], references: [id], onDelete: Cascade)
  journalistId  String
  journalist    User           @relation("ContentJournalist", fields: [journalistId], references: [id])
  configId      String?
  config        PaymentConfig? @relation("ContentPaymentConfig", fields: [configId], references: [id])

  baseAmount    Float
  bonusAmount   Float          @default(0)
  deductions    Float          @default(0)
  totalAmount   Float
  currency      String         @default("INR")

  status        PaymentStatus  @default(CALCULATED)
  approvedById  String?
  approvedAt    DateTime?
  paidAt        DateTime?
  transactionId String?
  paymentMethod String?

  note          String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([journalistId, status])
  @@index([status])
  @@map("content_payments")
}

// ============ PAGE BUILDER (Spec #2 — admin-editable templates for / and /category/[slug]) ============
// See docs/superpowers/specs/2026-05-25-page-builder-design.md
//
// Template       = named layout (block tree) with draft/published states.
// TemplateVersion= snapshot per publish; restorable into draft.
// TemplateAssignment = priority-ordered URL-pattern → template mapping.
// CompositeBlock = reusable named group of blocks; referenced by { type:"Composite", compositeId }.

model Template {
  id           String              @id @default(cuid())
  name         String
  slug         String              @unique
  description  String?
  // Published layout (block tree). Shape validated by Zod (layoutSchema).
  layout       Json
  // In-progress edits; promoted to `layout` on publish.
  draftLayout  Json?
  isPublished  Boolean             @default(false)
  publishedAt  DateTime?
  createdById  String
  createdBy    User                @relation("TemplateCreator", fields: [createdById], references: [id])
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  assignments  TemplateAssignment[]
  versions     TemplateVersion[]

  @@index([slug])
  @@map("templates")
}

model TemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  layout     Json
  editedById String
  editedBy   User     @relation(fields: [editedById], references: [id])
  editNote   String?
  createdAt  DateTime @default(now())

  @@index([templateId, createdAt])
  @@map("template_versions")
}

model TemplateAssignment {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  // URL pattern: "/", "/category/movie-reviews", "/category/*", "/category/**"
  pattern    String
  priority   Int      @default(10)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@unique([pattern, templateId])
  @@index([active, priority])
  @@map("template_assignments")
}

model CompositeBlock {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  // Array of block configs (same shape as layout.blocks). Zod-validated.
  blocks      Json
  createdById String
  createdBy   User     @relation("CompositeCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("composite_blocks")
}
