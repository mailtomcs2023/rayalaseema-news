generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER & AUTH ============

enum Role {
  ADMIN           // Full access - everything
  CHIEF_SUB_EDITOR // Edit all categories, publish, breaking news
  SUB_EDITOR      // Edit assigned categories, review articles, can't publish
  REPORTER        // Write articles, upload photos, submit for review only
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  // When true, the user MUST set a new password the next time they sign
  // in — the login flow blocks normal access until they pick one. Set by
  // admin "Reset password → require change on next sign-in".
  mustChangePassword Boolean @default(false)
  role          Role      @default(REPORTER)
  avatar        String?
  bio           String?
  phone         String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Category assignments (for SUB_EDITOR role)
  assignedCategories UserCategory[]

  // Articles authored
  articles      Article[]
  media         Media[]

  // Articles reviewed/edited by this user
  reviewedArticles ArticleReview[]

  // Article revisions authored by this user
  articleRevisions ArticleRevision[]

  // Audit log entries (actions performed by this user)
  auditLogs        AuditLog[]

  // Journalist profile (for REPORTER role)
  journalistProfile JournalistProfile?
  payments          ArticlePayment[]

  // Profile-change requests this user has reviewed (admin role)
  reviewedProfileUpdateRequests ProfileUpdateRequest[] @relation("ProfileUpdateRequestReviewer")

  @@map("users")
}

// ============ USER CATEGORY ASSIGNMENTS ============

model UserCategory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([userId])
  @@map("user_categories")
}

// ============ ARTICLE REVIEW LOG ============

model ArticleReview {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // "submitted", "reviewed", "approved", "rejected", "published", "edited"
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([articleId])
  @@index([userId])
  @@map("article_reviews")
}

// ============ AUDIT LOG (immutable, append-only — compliance + accountability) ============

model AuditLog {
  id          String   @id @default(cuid())

  // Actor — null if system / cron / unauthenticated action
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  actorEmail  String?  // denormalized (kept even if user deleted)
  actorRole   String?  // "ADMIN", "CHIEF_SUB_EDITOR", etc. at time of action

  // What happened
  action      String   // "article.create", "article.update", "article.delete", "article.publish",
                       // "article.restore", "user.create", "user.update", "user.role.change",
                       // "comment.approve", "settings.update", "auth.login", "auth.logout", "cron.publish-scheduled"
  resource    String?  // "article" | "user" | "category" | "comment" | "settings" | ...
  resourceId  String?  // ID of affected resource (nullable for global actions)

  // Optional structured payload — changes summary, IP, etc.
  meta        Json?
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============ ARTICLE REVISIONS (version history) ============

model ArticleRevision {
  id            String        @id @default(cuid())
  articleId     String
  article       Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)

  // Snapshot of mutable fields at the moment a save happened
  title         String
  slug          String
  summary       String?       @db.Text
  body          String        @db.Text
  featuredImage String?
  categoryId    String?
  status        ArticleStatus

  // Metadata
  editedById    String
  editedBy      User          @relation(fields: [editedById], references: [id])
  editNote      String?       // optional comment from editor
  bodyLength    Int           @default(0) // for lightweight diff stats in list view

  createdAt     DateTime      @default(now())

  @@index([articleId, createdAt])
  @@index([editedById])
  @@map("article_revisions")
}

// ============ CONTENT ============

enum ArticleStatus {
  DRAFT        // Reporter working on it
  SUBMITTED    // Reporter submitted for review
  IN_REVIEW    // Sub-editor is reviewing
  APPROVED     // Chief sub-editor approved, ready to publish
  SCHEDULED    // Approved + queued for auto-publish at scheduledAt
  PUBLISHED    // Live on website
  REJECTED     // Sent back to reporter with notes
  ARCHIVED     // Removed from site
}

enum Language {
  TELUGU
  ENGLISH
}

model Article {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  summary         String?       @db.Text // Short 60-word summary for app
  body            String        @db.Text
  featuredImage   String?
  imageCaption    String?
  language        Language      @default(TELUGU)
  status          ArticleStatus @default(DRAFT)
  featured        Boolean       @default(false)
  breaking        Boolean       @default(false)

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  // Movie review (only set for movie-reviews category articles)
  rating          Float?        // 0.0 - 5.0 star rating
  reviewerName    String?       // Critic byline for the review

  // Ingestion dedup — source news URL, unique so the same article can't be imported twice
  sourceUrl       String?       @unique

  // Scheduling
  publishedAt     DateTime?
  scheduledAt     DateTime?

  // Relations
  authorId        String
  author          User          @relation(fields: [authorId], references: [id])
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  tags            ArticleTag[]
  socialPosts     SocialPost[]
  comments        Comment[]

  // Location tagging
  constituencyId  String?
  constituency    Constituency? @relation("ArticleConstituency", fields: [constituencyId], references: [id])
  mandalId        String?
  mandal          Mandal?       @relation("ArticleMandal", fields: [mandalId], references: [id])

  // Analytics
  viewCount       Int           @default(0)

  // Editorial workflow
  rejectionNote   String?       @db.Text  // Feedback when rejected
  reviewedById    String?                 // Who reviewed this article
  reviewedAt      DateTime?               // When it was reviewed
  approvedById    String?                 // Who approved for publish
  approvedAt      DateTime?               // When approved
  reviews         ArticleReview[]
  revisions       ArticleRevision[]
  payment         ArticlePayment?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([constituencyId])
  @@index([slug])
  @@index([status, featured, publishedAt])
  @@index([categoryId, status, publishedAt])
  @@index([breaking])
  @@map("articles")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  nameEn      String?    // English name
  slug        String     @unique
  description String?
  color       String?    @default("#DC2626")
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)

  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")

  articles    Article[]
  videos      Video[]
  assignedUsers UserCategory[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("categories")
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  articles  ArticleTag[]

  @@map("tags")
}

model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

// ============ MEDIA ============

enum MediaType {
  IMAGE
  VIDEO
  PDF
  DOCUMENT
}

model Media {
  id          String    @id @default(cuid())
  url         String
  filename    String
  altText     String?
  type        MediaType @default(IMAGE)
  size        Int       // bytes
  width       Int?
  height      Int?
  uploadedById String
  uploadedBy  User      @relation(fields: [uploadedById], references: [id])
  createdAt   DateTime  @default(now())

  @@map("media")
}

// ============ ePAPER ============

model EpaperEdition {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  edition     String   @default("main") // "main" or a district slug — one paper per district
  title       String?
  pdfUrl      String?  // combined PDF — set once generation finishes
  thumbnailUrl String?
  pageCount   Int      @default(0)
  layout      Json?    // editable plan — [{label,isFront,slots:{lead,majors[],secondary[],briefs[]}}]
  status      String   @default("pending") // pending | draft | generating | ready | failed
  active      Boolean  @default(true)
  pages       EpaperPage[]
  ads         EpaperAd[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, edition])
  @@index([date])
  @@map("epaper_editions")
}

model EpaperAd {
  id          String         @id @default(cuid())
  editionId   String
  edition     EpaperEdition  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  pageNumber  Int            // which page this ad sits on
  slot        String         // "top" | "bottom"
  imageUrl    String         // ad creative on Azure Blob
  linkUrl     String?
  createdAt   DateTime       @default(now())

  @@index([editionId])
  @@map("epaper_ads")
}

model EpaperPage {
  id          String         @id @default(cuid())
  editionId   String
  edition     EpaperEdition  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  pageNumber  Int
  label       String         // "ముఖ్యాంశాలు", "రాజకీయం", ...
  imageUrl    String         // rendered broadsheet page PNG on Azure Blob
  hotspots    Json?          // [{slug,x,y,w,h}] — percentage boxes, clickable story regions
  createdAt   DateTime       @default(now())

  @@unique([editionId, pageNumber])
  @@index([editionId])
  @@map("epaper_pages")
}

// ============ BREAKING NEWS ============

model BreakingNews {
  id          String   @id @default(cuid())
  headline    String
  headlineEn  String?
  url         String?  // optional link to article
  priority    Int      @default(0)
  active      Boolean  @default(true)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("breaking_news")
}

// ============ SOCIAL MEDIA ============

enum SocialPlatform {
  FACEBOOK
  TWITTER
  INSTAGRAM
  WHATSAPP
  TELEGRAM
  YOUTUBE
}

enum SocialPostStatus {
  QUEUED
  POSTED
  FAILED
}

model SocialPost {
  id          String           @id @default(cuid())
  articleId   String
  article     Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  platform    SocialPlatform
  status      SocialPostStatus @default(QUEUED)
  postUrl     String?
  error       String?
  postedAt    DateTime?
  createdAt   DateTime         @default(now())

  @@unique([articleId, platform])
  @@map("social_posts")
}

// ============ SITE CONFIG ============

model SiteConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  description String?
  updatedAt   DateTime @updatedAt

  @@map("site_config")
}

// ============ LOCATIONS (Districts → Constituencies → Mandals) ============

model District {
  id              String          @id @default(cuid())
  name            String          // Telugu name
  nameEn          String          // English name
  slug            String          @unique
  loksabhaSeats   String?         // Comma-separated Lok Sabha constituency names
  sortOrder       Int             @default(0)
  active          Boolean         @default(true)
  constituencies  Constituency[]
  createdAt       DateTime        @default(now())

  @@map("districts")
}

/// Assembly Constituency (AC). acNumber = official ECI delimitation number (e.g. 137 = Kurnool).
model Constituency {
  id          String   @id @default(cuid())
  name        String   // Telugu name
  nameEn      String   // English name
  slug        String   @unique
  acNumber    Int?     @unique  // Official ECI AC number (120..175 for Rayalaseema)
  type        String   @default("ASSEMBLY") // ASSEMBLY or LOKSABHA
  districtId  String
  district    District @relation(fields: [districtId], references: [id])
  loksabha    String?  // Which Lok Sabha seat this falls under
  mandals     Mandal[]
  articles    Article[] @relation("ArticleConstituency")
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([districtId])
  @@map("constituencies")
}

model Mandal {
  id              String       @id @default(cuid())
  name            String       // Telugu name
  nameEn          String       // English name
  slug            String       @unique
  code            Int?         @unique  // Official AP mandal code (e.g. 5259 = Kurnool)
  constituencyId  String
  constituency    Constituency @relation(fields: [constituencyId], references: [id])
  articles        Article[]    @relation("ArticleMandal")
  sortOrder       Int          @default(0)
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now())

  @@index([constituencyId])
  @@map("mandals")
}

// ============ VIDEOS ============

model Video {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?  @db.Text
  thumbnailUrl String
  videoUrl    String?  // YouTube/external URL
  duration    String?  // "12:45"
  views       Int      @default(0)
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, featured])
  @@map("videos")
}

// ============ PHOTO GALLERY ============

model PhotoGallery {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String?
  coverImage  String
  active      Boolean       @default(true)
  photos      GalleryPhoto[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("photo_galleries")
}

model GalleryPhoto {
  id          String       @id @default(cuid())
  galleryId   String
  gallery     PhotoGallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)
  imageUrl    String
  caption     String?
  sortOrder   Int          @default(0)

  @@map("gallery_photos")
}

// ============ WEB STORIES ============

model WebStory {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  imageUrl    String
  category    String?  // devotional, travel, food, history, etc.
  active      Boolean  @default(true)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("web_stories")
}

// ============ REELS ============

model Reel {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  thumbnailUrl String
  videoUrl    String?
  views       String   @default("0") // "2.5L", "95K" etc.
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("reels")
}

// ============ CARTOON (YETTETA) ============

model Cartoon {
  id          String   @id @default(cuid())
  title       String
  caption     String
  imageUrl    String
  date        DateTime @db.Date
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([date])
  @@map("cartoons")
}

// ============ ADS ============

enum AdPosition {
  HEADER_LEFT
  HEADER_RIGHT
  BANNER_MID
  SIDEBAR_SQUARE
  SIDEBAR_TALL
  LEADERBOARD
  IN_FEED
  VERTICAL_STRIP
}

model Ad {
  id          String     @id @default(cuid())
  name        String
  position    AdPosition
  imageUrl    String?
  linkUrl     String?
  htmlContent String?    @db.Text // custom HTML ad
  bgColor     String?
  textColor   String?
  active      Boolean    @default(true)
  startDate   DateTime?
  endDate     DateTime?
  clicks      Int        @default(0)
  impressions Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([position, active])
  @@map("ads")
}

// ============ COMMENTS ============

model Comment {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  content   String   @db.Text
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([articleId, approved])
  @@index([approved, createdAt])
  @@map("comments")
}

// ============ MANDI PRICES ============

model MandiPrice {
  id        String   @id @default(cuid())
  commodity String   // e.g. "మిర్చి", "పత్తి"
  commodityEn String // e.g. "Chilli", "Cotton"
  market    String   // e.g. "కర్నూలు"
  marketEn  String   // e.g. "Kurnool"
  price     Float    // price per quintal in Rs
  unit      String   @default("క్వింటల్")
  change    Float    @default(0) // daily change percentage
  date      DateTime @default(now())
  active    Boolean  @default(true)

  @@index([date, active])
  @@map("mandi_prices")
}

// ============ POLLS ============

model Poll {
  id        String       @id @default(cuid())
  question  String
  active    Boolean      @default(true)
  options   PollOption[]
  createdAt DateTime     @default(now())
  expiresAt DateTime?

  @@map("polls")
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text   String
  votes  Int    @default(0)

  @@index([pollId])
  @@map("poll_options")
}

// ============ JOURNALIST PROFILE & KYC ============

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  REJECTED
}

model JournalistProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Personal
  fullName        String
  fatherName      String?
  dateOfBirth     DateTime?
  gender          String?
  address         String?   @db.Text
  city            String?
  pincode         String?

  // District assignment
  primaryDistrict String?   // District slug they cover
  secondaryDistricts String[] // Additional districts

  // KYC documents
  kycStatus       KycStatus @default(PENDING)
  aadhaarNumber   String?
  aadhaarFrontUrl String?   // Uploaded image
  aadhaarBackUrl  String?
  panNumber       String?
  panCardUrl      String?
  idCardUrl       String?   // Press/company ID
  photoUrl        String?   // Passport photo

  // Bank / Payment
  upiId           String?
  bankName        String?
  bankAccount     String?
  bankIfsc        String?
  bankBranch      String?

  // Experience
  experience      String?   @db.Text // Previous media experience
  languages       String[]            // ["Telugu", "English", "Hindi"]
  specialization  String?             // "Politics", "Crime", etc.

  // App specific
  deviceToken     String?   // Push notification token
  lastActiveAt    DateTime?

  kycRejectionNote String?
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Reporter-initiated edits awaiting (or completed by) admin review
  profileUpdateRequests ProfileUpdateRequest[]

  @@map("journalist_profiles")
}

// ============ PROFILE UPDATE REQUESTS (reporter -> admin approval) ============

enum ProfileUpdateRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// A single field-level change the reporter wants applied to their profile.
// One PENDING request per (journalistProfileId, field) at a time; re-requesting
// the same field replaces the prior PENDING request.
//
// `oldValue` / `newValue` are stored as text (arrays/dates are JSON-stringified).
// `previousKycStatus` is captured when the request is for a KYC-critical field,
// so we can restore it if admin rejects (we flip the journalist's kycStatus to
// SUBMITTED on submission to pause earnings until re-verification).
model ProfileUpdateRequest {
  id                  String                     @id @default(cuid())
  journalistProfileId String
  journalistProfile   JournalistProfile          @relation(fields: [journalistProfileId], references: [id], onDelete: Cascade)

  field               String                     // e.g. "name", "phone", "aadhaarNumber", "bankIfsc"
  oldValue            String?                    @db.Text
  newValue            String?                    @db.Text

  status              ProfileUpdateRequestStatus @default(PENDING)
  previousKycStatus   KycStatus?                 // restored on REJECT for KYC-critical fields

  reviewerNote        String?                    @db.Text
  reviewedById        String?
  reviewedBy          User?                      @relation("ProfileUpdateRequestReviewer", fields: [reviewedById], references: [id])
  reviewedAt          DateTime?

  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([journalistProfileId, status])
  @@index([status, createdAt])
  @@map("profile_update_requests")
}

// ============ PAYMENT CONFIG (admin-configurable rates) ============

model PaymentConfig {
  id          String   @id @default(cuid())
  articleType String   @unique // "text_news", "photo_news", "video_story", "exclusive", "breaking"
  name        String            // Display name: "Text News (300+ words)"
  nameTE      String?           // Telugu name
  rate        Float             // Base rate in Rs
  minWords    Int     @default(0)  // Minimum word count required
  requiresImage Boolean @default(false)
  requiresVideo Boolean @default(false)
  bonusRate   Float   @default(0) // Bonus per 1000 views
  active      Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  payments    ArticlePayment[]

  @@map("payment_configs")
}

// ============ ARTICLE PAYMENT ============

enum PaymentStatus {
  CALCULATED  // Auto-calculated when article published
  APPROVED    // Admin approved for payout
  PROCESSING  // Payment being processed
  PAID        // Money transferred
  DISPUTED    // Journalist raised dispute
}

model ArticlePayment {
  id            String        @id @default(cuid())
  articleId     String        @unique
  article       Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)
  journalistId  String
  journalist    User          @relation(fields: [journalistId], references: [id])
  configId      String?
  config        PaymentConfig? @relation(fields: [configId], references: [id])

  // Payment details
  baseAmount    Float         // Rate from config
  bonusAmount   Float         @default(0)  // View-based bonus
  deductions    Float         @default(0)  // Any deductions
  totalAmount   Float         // Final amount
  currency      String        @default("INR")

  status        PaymentStatus @default(CALCULATED)
  approvedById  String?
  approvedAt    DateTime?
  paidAt        DateTime?
  transactionId String?       // UPI/bank ref number
  paymentMethod String?       // "UPI", "bank_transfer"

  note          String?       // Admin note
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([journalistId, status])
  @@index([status])
  @@map("article_payments")
}

// ============ PAYOUT BATCH ============

model PayoutBatch {
  id            String   @id @default(cuid())
  month         Int      // 1-12
  year          Int
  totalAmount   Float
  totalArticles Int
  totalJournalists Int
  status        String   @default("DRAFT") // DRAFT, APPROVED, PROCESSING, COMPLETED
  approvedById  String?
  approvedAt    DateTime?
  completedAt   DateTime?
  note          String?
  createdAt     DateTime @default(now())

  @@unique([month, year])
  @@map("payout_batches")
}
