generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ USER & AUTH ============

enum Role {
  ADMIN           // Full access - everything
  EDITOR          // Edit all categories, publish, breaking news (was CHIEF_SUB_EDITOR)
  SUB_EDITOR      // Edit assigned categories, review articles, can't publish
  REPORTER        // Write articles, upload photos, submit for review only
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  // When true, the user MUST set a new password the next time they sign
  // in — the login flow blocks normal access until they pick one. Set by
  // admin "Reset password → require change on next sign-in".
  mustChangePassword Boolean @default(false)
  role          Role      @default(REPORTER)
  avatar        String?
  bio           String?
  phone         String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Category assignments (for SUB_EDITOR role)
  assignedCategories UserCategory[]

  // Articles authored
  articles      Article[]
  media         Media[]

  // Articles reviewed/edited by this user
  reviewedArticles ArticleReview[]

  // Article revisions authored by this user
  articleRevisions ArticleRevision[]

  // ePaper edition snapshots created by this user
  epaperSnapshots EpaperEditionSnapshot[]
  // ePaper comments authored by this user
  epaperComments  EpaperComment[]

  // Audit log entries (actions performed by this user)
  auditLogs        AuditLog[]

  // Journalist profile (for REPORTER role)
  journalistProfile JournalistProfile?
  payments          ArticlePayment[]

  // Unified Content (Spec #1) — back-relations parallel to Article side
  contents          Content[]         @relation("ContentAuthor")
  contentRevisions  ContentRevision[]
  contentPayments   ContentPayment[]  @relation("ContentJournalist")

  // Page Builder (Spec #2) — back-relations
  templates         Template[]         @relation("TemplateCreator")
  templateVersions  TemplateVersion[]
  composites        CompositeBlock[]   @relation("CompositeCreator")

  // Profile-change requests this user has reviewed (admin role)
  reviewedProfileUpdateRequests ProfileUpdateRequest[] @relation("ProfileUpdateRequestReviewer")

  @@map("users")
}

// ============ USER CATEGORY ASSIGNMENTS ============

model UserCategory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([userId])
  @@map("user_categories")
}

// ============ ARTICLE REVIEW LOG ============

model ArticleReview {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // "submitted", "reviewed", "approved", "rejected", "published", "edited"
  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([articleId])
  @@index([userId])
  @@map("article_reviews")
}

// ============ AUDIT LOG (immutable, append-only — compliance + accountability) ============

model AuditLog {
  id          String   @id @default(cuid())

  // Actor — null if system / cron / unauthenticated action
  actorId     String?
  actor       User?    @relation(fields: [actorId], references: [id])
  actorEmail  String?  // denormalized (kept even if user deleted)
  actorRole   String?  // "ADMIN", "CHIEF_SUB_EDITOR", etc. at time of action

  // What happened
  action      String   // "article.create", "article.update", "article.delete", "article.publish",
                       // "article.restore", "user.create", "user.update", "user.role.change",
                       // "comment.approve", "settings.update", "auth.login", "auth.logout", "cron.publish-scheduled"
  resource    String?  // "article" | "user" | "category" | "comment" | "settings" | ...
  resourceId  String?  // ID of affected resource (nullable for global actions)

  // Optional structured payload — changes summary, IP, etc.
  meta        Json?
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([resource, resourceId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============ ARTICLE REVISIONS (version history) ============

model ArticleRevision {
  id            String        @id @default(cuid())
  articleId     String
  article       Article       @relation(fields: [articleId], references: [id], onDelete: Cascade)

  // Snapshot of mutable fields at the moment a save happened
  title         String
  slug          String
  summary       String?       @db.Text
  body          String        @db.Text
  featuredImage String?
  categoryId    String?
  status        ArticleStatus

  // Metadata
  editedById    String
  editedBy      User          @relation(fields: [editedById], references: [id])
  editNote      String?       // optional comment from editor
  bodyLength    Int           @default(0) // for lightweight diff stats in list view

  createdAt     DateTime      @default(now())

  @@index([articleId, createdAt])
  @@index([editedById])
  @@map("article_revisions")
}

// ============ CONTENT ============

enum ArticleStatus {
  DRAFT        // Reporter working on it
  SUBMITTED    // Reporter submitted for review
  IN_REVIEW    // Sub-editor is reviewing
  APPROVED     // Chief sub-editor approved, ready to publish
  SCHEDULED    // Approved + queued for auto-publish at scheduledAt
  PUBLISHED    // Live on website
  REJECTED     // Sent back to reporter with notes
  ARCHIVED     // Removed from site
}

enum Language {
  TELUGU
  ENGLISH
}

model Article {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  summary         String?       @db.Text // Short 60-word summary for app
  body            String        @db.Text
  featuredImage   String?
  imageCaption    String?
  language        Language      @default(TELUGU)
  status          ArticleStatus @default(DRAFT)
  featured        Boolean       @default(false)
  breaking        Boolean       @default(false)

  // SEO
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  // PIB approval workflow (#99) — when needsPibApproval is true the
  // publish gate refuses to flip status to PUBLISHED until pibApprovedAt
  // + pibReferenceNumber are stamped by an ADMIN.
  needsPibApproval     Boolean   @default(false)
  pibApprovedAt        DateTime?
  pibApprovedById      String?
  pibReferenceNumber   String?

  // Movie review (only set for movie-reviews category articles)
  rating          Float?        // 0.0 - 5.0 star rating
  reviewerName    String?       // Critic byline for the review

  // Ingestion dedup — source news URL, unique so the same article can't be imported twice
  sourceUrl       String?       @unique

  // Scheduling
  publishedAt     DateTime?
  scheduledAt     DateTime?

  // Relations
  authorId        String
  author          User          @relation(fields: [authorId], references: [id])
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  tags            ArticleTag[]
  socialPosts     SocialPost[]
  comments        Comment[]

  // Location tagging
  constituencyId  String?
  constituency    Constituency? @relation("ArticleConstituency", fields: [constituencyId], references: [id])
  mandalId        String?
  mandal          Mandal?       @relation("ArticleMandal", fields: [mandalId], references: [id])

  // Desk byline (auto-picked on save unless editor overrides; see lib/desk-resolver.ts)
  deskId          String?
  desk            Desk?         @relation(fields: [deskId], references: [id])

  // Analytics
  viewCount       Int           @default(0)

  // Editorial workflow
  rejectionNote   String?       @db.Text  // Feedback when rejected
  reviewedById    String?                 // Who reviewed this article
  reviewedAt      DateTime?               // When it was reviewed
  approvedById    String?                 // Who approved for publish
  approvedAt      DateTime?               // When approved
  reviews         ArticleReview[]
  revisions       ArticleRevision[]
  payment         ArticlePayment?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([categoryId])
  @@index([authorId])
  @@index([constituencyId])
  @@index([deskId])
  @@index([slug])
  @@index([status, featured, publishedAt])
  @@index([categoryId, status, publishedAt])
  @@index([breaking])
  @@map("articles")
}

model Category {
  id          String     @id @default(cuid())
  name        String
  nameEn      String?    // English name
  slug        String     @unique
  description String?
  color       String?    @default("#DC2626")
  sortOrder   Int        @default(0)
  active      Boolean    @default(true)

  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")

  articles    Article[]
  videos      Video[]
  contents    Content[]
  assignedUsers UserCategory[]
  desk        Desk?      // back-relation: TOPICAL desk auto-derived from category

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("categories")
}

model Tag {
  id          String       @id @default(cuid())
  name        String       @unique
  slug        String       @unique
  articles    ArticleTag[]
  contentTags ContentTag[]

  @@map("tags")
}

model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

// ============ MEDIA ============

enum MediaType {
  IMAGE
  VIDEO
  PDF
  DOCUMENT
}

model Media {
  id          String    @id @default(cuid())
  url         String
  filename    String
  altText     String?
  type        MediaType @default(IMAGE)
  size        Int       // bytes
  width       Int?
  height      Int?
  uploadedById String
  uploadedBy  User      @relation(fields: [uploadedById], references: [id])
  createdAt   DateTime  @default(now())

  @@map("media")
}

// ============ ePAPER ============

/// Telugu spell-check ignore-list (#91). Tokens that should NOT trigger
/// the COMMON_TYPOS scanner. Scoped optionally to a desk so beat reporters
/// can curate proper-noun lists for their territory.
model EpaperSpellIgnore {
  id        String   @id @default(cuid())
  token     String
  deskId    String?  // null = global ignore
  note      String?
  addedById String?
  createdAt DateTime @default(now())

  @@unique([token, deskId])
  @@map("epaper_spell_ignore")
}

/// Rayalaseema dialect glossary (#96). Maps regional dialect words to
/// standard Telugu so non-region readers see a tooltip explanation on
/// article pages. Curated by editorial team — small enough to ship the
/// whole list to the client on article render.
model DialectGloss {
  id              String   @id @default(cuid())
  token           String   @unique
  standardTelugu  String
  region          String?  // "rayalaseema" | "ananthapuramu" | "chittoor" — narrowing optional
  note            String?
  addedById       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("dialect_glosses")
}

/// A/B headline test (#94). Two headline variants for the same article;
/// push notifications split 50/50, clicks counted via the redirect endpoint.
/// After a settle window the winner is auto-promoted to Article.title.
model HeadlineTest {
  id           String   @id @default(cuid())
  articleId    String
  variantA     String
  variantB     String
  sentAt       DateTime?
  clicksA      Int      @default(0)
  clicksB      Int      @default(0)
  winnerVariant String? // "A" | "B" | null while running
  winnerAt     DateTime?
  createdById  String?
  createdAt    DateTime @default(now())

  @@index([articleId])
  @@index([winnerVariant])
  @@map("headline_tests")
}

/// Paywall metering (#93). One row per unique-article read by an anonymous
/// (non-logged-in) reader. Fingerprint = SHA-256(UA + IP hash + lang) — no
/// PII. Rolling 30-day window decides when the paywall modal triggers.
/// Logged-in readers don't get tracked here (subscription bypass).
model ArticleReadEvent {
  id          String   @id @default(cuid())
  fingerprint String   // SHA-256 of UA + IP-hash + lang
  articleSlug String
  createdAt   DateTime @default(now())

  @@index([fingerprint, createdAt])
  @@index([articleSlug])
  @@map("article_read_events")
}

/// Render-job log (#90) — one row per render-v2 invocation. Powers the SLA
/// dashboard (P50/P95/P99 + success rate) and lets us see retries + errors
/// without scraping app logs.
model EpaperRenderJob {
  id          String   @id @default(cuid())
  editionId   String
  triggeredById String?
  status      String   // "queued" | "running" | "succeeded" | "failed"
  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?
  retries     Int      @default(0)
  pageCount   Int?
  pdfSizeBytes Int?
  lastError   String?
  createdAt   DateTime @default(now())

  @@index([editionId])
  @@index([status])
  @@index([createdAt])
  @@map("epaper_render_jobs")
}

enum EpaperWorkflowState {
  DRAFT             // operator is laying out
  SUB_REVIEW        // sub-editor needs to read it
  CHIEF_REVIEW      // chief editor needs final say
  APPROVED          // ready to publish; render + push runs
  PUBLISHED         // out to readers
  REJECTED          // sent back with a note
  KILLED            // retracted after publish — hidden from /epaper, logged on /epaper/corrections
}

model EpaperEdition {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  edition     String   @default("main") // "main" or a district slug — one paper per district
  title       String?
  pdfUrl      String?  // combined PDF — set once generation finishes
  thumbnailUrl String?
  pageCount   Int      @default(0)
  layout      Json?    // editable plan — [{label,isFront,slots:{lead,majors[],secondary[],briefs[]}}]
  status      String   @default("pending") // RENDER lifecycle: pending | draft | generating | ready | failed
  workflowState EpaperWorkflowState @default(DRAFT) // EDITORIAL approval workflow
  workflowNote  String? // last transition's note (rejection reason etc.)
  active      Boolean  @default(true)
  // Retraction / kill switch (#88) — when set, edition is hidden from readers
  // but persists in DB + appears on /epaper/corrections with the kill reason.
  killedAt    DateTime?
  killedReason String?
  killedById  String?
  // Masthead bibliographic fields (Eenadu-style): సంపుటి / సంచిక / price.
  // Optional — defaults applied at render time if null. Set per-edition by
  // operator or autoincremented from a known epoch.
  volumeNumber Int?
  issueNumber  Int?
  priceInPaise Int?    @default(650)  // Rs 6.50 default
  // v2 editor (#108): per-edition PageGeometry override (defaults apply if
  // null). Lets ops run a special-format edition (e.g. tabloid Sunday) w/o
  // re-templating the whole system.
  pageGeometry Json?
  // v2 editor (#108): which ad asset fills each masthead slot for THIS edition.
  // Keyed by slot name from the master block (e.g. { "ad-left": "<assetId>", "ad-right": "<assetId>" }).
  // Render falls back to auto-pick from EpaperAdAsset library when a slot key
  // is missing or the asset has been deactivated.
  mastheadAds  Json?
  pages       EpaperPage[]
  ads         EpaperAd[]
  snapshots   EpaperEditionSnapshot[]
  comments    EpaperComment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, edition])
  @@index([date])
  @@map("epaper_editions")
}

model EpaperAd {
  id          String         @id @default(cuid())
  editionId   String
  edition     EpaperEdition  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  pageNumber  Int            // which page this ad sits on
  slot        String         // "top" | "bottom"
  imageUrl    String         // ad creative on Azure Blob
  linkUrl     String?
  createdAt   DateTime       @default(now())

  @@index([editionId])
  @@map("epaper_ads")
}

enum EpaperImageAssetCategory {
  CARTOON
  CLASSIFIED
  MASTHEAD
  PHOTO
  GRAPHIC
  OTHER
}

/// Generic image library for the e-paper editor — cartoons, classifieds,
/// masthead variants, stock photos etc. `image` blocks reference these
/// by `assetId`. Separate from EpaperAdAsset because ads carry pricing /
/// advertiser metadata that doesn't apply to a cartoon.
model EpaperImageAsset {
  id          String                       @id @default(cuid())
  category    EpaperImageAssetCategory     @default(OTHER)
  title       String                       // operator label, e.g. "Saturday cartoon — markets"
  imageUrl    String                       // Azure Blob URL
  caption     String?                      // optional caption rendered under the image in some templates
  tags        String?                      // comma-separated for quick text search
  active      Boolean                      @default(true)
  // Image rights tracking (#98) — required before render-time use so we
  // never publish an unlicensed photo.
  licenseType String?                      // "STAFF" | "AGENCY" | "WIRE" | "UGC" | "CC0" | "CC-BY" | "PURCHASED"
  licenseSource String?                    // "PTI" | "Reuters" | reporter name | URL
  licenseExpiresAt DateTime?
  copyrightHolder String?
  attributionText String?                  // rendered under image as required
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  @@index([category, active])
  @@index([licenseType])
  @@map("epaper_image_assets")
}

/// Reusable ad asset library. Each `ad` block in an EpaperPage layout
/// references one of these by id. Separate from per-edition placement so the
/// same creative can run across multiple editions without re-upload.
model EpaperAdAsset {
  id          String   @id @default(cuid())
  advertiser  String   // e.g. "Heritage Foods", for ops + reporting
  imageUrl    String   // Azure Blob URL
  linkUrl     String?  // click-through (rendered as <a href>)
  validFrom   DateTime?
  validTo     DateTime?
  active      Boolean  @default(true)
  price       Int?     // monthly run price in paise; informational
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active, validFrom, validTo])
  @@map("epaper_ad_assets")
}

model EpaperPage {
  id          String         @id @default(cuid())
  editionId   String
  edition     EpaperEdition  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  pageNumber  Int
  label       String         // "ముఖ్యాంశాలు", "రాజకీయం", ...
  templateSlug String?       // → EpaperTemplate.slug — which template this page was built from
  // Per-page WYSIWYG layout. v2 editor (#108) shape:
  //   { coordSystem: "grid-v1" | "mm-v2",
  //     masterSlug?: string,         // master to inherit (overrides template.masterSlug per-page)
  //     blocks: [{
  //       id, type,                  // "lead" | "major" | "secondary" | "brief" | "image" | "ad" | "text" | "masthead" | "section-band" | "story-jump" | "pull-quote" | "folio"
  //       x, y, w, h,                // mm-v2 = absolute mm coords; grid-v1 = 12-col x 30-row grid units
  //       articleId?, content?, href?, targetPage?, adAssetId?,
  //       locked?: boolean,          // operator locked → auto-fill won't replace
  //       isOverride?: boolean,      // true if detached from master
  //       slots?: [{ name, x, y, w, h }],  // masthead ad slots
  //       style?: object,
  //     }] }
  // Legacy layouts (no coordSystem field) treated as grid-v1; auto-migrated
  // to mm-v2 on first save via migrateLegacyLayout().
  layout      Json?
  imageUrl    String         // rendered broadsheet page PNG on Azure Blob (legacy raster path)
  pdfUrl      String?        // per-page vector PDF (new v2 render path)
  hotspots    Json?          // [{slug,x,y,w,h}] — legacy raster overlay click regions
  comments    EpaperComment[]
  // Optimistic concurrency token. Bumps on every successful PATCH; client must
  // send the version it last fetched so two editors can't silently overwrite
  // each other. Server returns 409 if expected != current.
  version     Int            @default(1)
  // OCR'd text for legacy/uploaded PDFs that don't carry article-DB
  // references (#89). Populated by background OCR worker (Tesseract tel+eng);
  // exposed via /api/epaper/search alongside live-article hits.
  ocrText     String?
  ocrAt       DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt

  @@unique([editionId, pageNumber])
  @@index([editionId])
  @@map("epaper_pages")
}

/// E-paper viewer analytics: each row = one view OR one hotspot click.
/// Tracked client-side from /epaper viewer; never PII, just edition + page +
/// optional clicked article slug. Bucketed query roll-ups feed
/// /epaper-analytics admin dashboard.
model EpaperPageView {
  id          String   @id @default(cuid())
  editionId   String
  pageNumber  Int
  articleSlug String?  // when set, this row records a hotspot click on that article
  referrer    String?
  ipHash      String?  // sha256(ip + UA) — for unique-visitor approximations w/o storing PII
  createdAt   DateTime @default(now())

  @@index([editionId, createdAt])
  @@index([editionId, pageNumber])
  @@index([articleSlug])
  @@map("epaper_page_views")
}

/// Editorial comments on an e-paper edition. Scoped to a specific block (when
/// `blockId` is set) or to a whole page (when `blockId` is null). Used by the
/// chief editor to leave notes like "swap this lead" without WhatsApp ping.
model EpaperComment {
  id          String         @id @default(cuid())
  editionId   String
  edition     EpaperEdition  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  pageId      String
  page        EpaperPage     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  blockId     String?        // null = applies to whole page; set = applies to that block
  text        String         @db.Text
  resolved    Boolean        @default(false)
  authorId    String
  author      User           @relation(fields: [authorId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([editionId, resolved])
  @@index([pageId])
  @@map("epaper_comments")
}

/// Point-in-time snapshot of an edition's per-page layouts. Created
/// automatically before each Render and on demand from the "History" panel
/// in the /epaper editor. Restoring an edition writes a fresh snapshot of
/// the current state first, then overwrites all pages from the chosen
/// snapshot — so rollback is itself undoable.
model EpaperEditionSnapshot {
  id          String         @id @default(cuid())
  editionId   String
  edition     EpaperEdition  @relation(fields: [editionId], references: [id], onDelete: Cascade)
  // [{ pageNumber, label, templateSlug, layout, version }] — one entry per
  // EpaperPage at the moment of capture.
  pages       Json
  reason      String         // "pre-render" | "manual" | "pre-regenerate" | "pre-restore"
  note        String?        // operator-supplied label, e.g. "before homepage swap"
  snappedById String?
  snappedBy   User?          @relation(fields: [snappedById], references: [id])
  createdAt   DateTime       @default(now())

  @@index([editionId, createdAt])
  @@map("epaper_edition_snapshots")
}

enum EpaperTemplateType {
  FRONT       // front page — lead + majors + briefs + ad band
  DISTRICT    // per-district edition page
  SECTION     // sports / cinema / editorial / classifieds / etc.
  BACK        // back page
}

/// Reusable page layouts. DTP staff curates these JSON blocks once; the
/// auto-fill engine then drops the day's articles into matching slots.
model EpaperTemplate {
  id            String              @id @default(cuid())
  slug          String              @unique          // "front", "district-kurnool", "section-sports", ...
  name          String                               // "Front Page" / "Sports Section"
  type          EpaperTemplateType
  // Default label rendered in the section-band block of the produced page
  // (e.g. "క్రీడలు" for sports). When `type = DISTRICT` the label is dynamic.
  defaultLabel  String?
  // Optional filters used by the auto-fill engine when matching articles to
  // slots inside this template (e.g. `{ "categorySlug": "sports" }` or
  // `{ "districtSlug": "kurnool" }`).
  fillRules     Json?
  // Block layout — same shape as EpaperPage.layout but with empty articleIds.
  layout        Json
  // v2 editor (#108): which EpaperMaster the produced pages inherit from.
  // null = no master (legacy templates / unstyled section pages).
  masterSlug    String?
  sortOrder     Int                 @default(0)
  active        Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([type])
  @@index([masterSlug])
  @@map("epaper_templates")
}

/// Reusable master page for the v2 editor (#108). Holds repeating elements
/// (masthead, folio, cities band, footer) that propagate across every page
/// inheriting the master. InDesign-style "Parent page" concept.
///
/// Block shape inside layout JSON matches EpaperPage.blocks. Special block
/// type "folio" supports {{pageNumber}} / {{dateLabel}} / {{sectionLabel}}
/// placeholders that render-layout substitutes at render time.
///
/// masthead blocks may carry `slots: [{ name, x, y, w, h }]`. The editor
/// renders each slot as a click target that opens the ad-asset picker;
/// per-edition selection lives in EpaperEdition.mastheadAds.
model EpaperMaster {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  geometryOverride Json?    // optional PageGeometry override (defaults apply if null)
  layout          Json     // { blocks: Block[] } — every block has isMaster:true
  version         Int      @default(1)  // bumps on update for optimistic concurrency
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("epaper_masters")
}

// ============ BREAKING NEWS ============

model BreakingNews {
  id          String   @id @default(cuid())
  headline    String
  headlineEn  String?
