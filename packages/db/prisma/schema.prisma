// ============ SOCIAL MEDIA ============

enum SocialPlatform {
  FACEBOOK
  TWITTER
  INSTAGRAM
  WHATSAPP
  TELEGRAM
  YOUTUBE
}

enum SocialPostStatus {
  QUEUED
