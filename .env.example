# ============================================================
# Rayalaseema News — environment template
# Copy to apps/web/.env AND apps/admin/.env, then fill values.
# ============================================================

# ---------- REQUIRED — app will not run without these ----------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rayalaseema_news"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3001"          # admin app URL
SITE_URL="http://localhost:3000"               # web app URL

# ---------- OPTIONAL — feature degrades if blank, app still boots ----------

# Azure OpenAI — Telugu translation (auto-publish, AI rewrite).
# Blank -> translation routes return 503 "not configured".
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_KEY=""
AZURE_OPENAI_DEPLOYMENT="gpt51"
AZURE_OPENAI_API_VERSION="2024-10-21"

# NewsData.io — external news ingestion. Blank -> fetch routes 503.
NEWSDATA_API_KEY=""

# Azure Blob Storage — image uploads, e-paper render, clip-to-share.
# Blank -> upload / epaper / clip routes return 503.
AZURE_STORAGE_CONNECTION_STRING=""

# RapidAPI "Cricket API Free Data" — sports live scores.
# Blank -> sports rail shows fixtures only, no live scores.
RAPIDAPI_CRICKET_KEY=""

# Azure Speech — article text-to-speech. Blank -> TTS button inert.
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION="centralindia"
AZURE_SPEECH_VOICE="te-IN-MohanNeural"

# Cron — scheduled publish. Generate: openssl rand -base64 32
CRON_SECRET=""

# Redis — caching (optional; falls back to in-process).
REDIS_URL="redis://localhost:6379"

# ---------- SOCIAL MEDIA (optional, all features off if blank) ----------
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHANNEL_ID=""
# TWITTER_API_KEY=""
# TWITTER_API_SECRET=""
# TWITTER_ACCESS_TOKEN=""
# TWITTER_ACCESS_SECRET=""
# FACEBOOK_PAGE_TOKEN=""
# FACEBOOK_PAGE_ID=""
# INSTAGRAM_ACCOUNT_ID=""
# LINKEDIN_ACCESS_TOKEN=""
# LINKEDIN_ORG_ID=""
# WHATSAPP_TOKEN=""
# WHATSAPP_PHONE_ID=""
# WHATSAPP_GROUP_ID=""
# PINTEREST_ACCESS_TOKEN=""
# PINTEREST_BOARD_ID=""

# ---------- DNS — GoDaddy API (rayalaseemanews.com) ----------
# Used by scripts/dns/godaddy-set-records.ts to point DNS at Azure VM.
# Get keys: https://developer.godaddy.com/keys. Production keys only.
GODADDY_API_KEY=""
GODADDY_API_SECRET=""
GODADDY_API_BASE="https://api.godaddy.com/v1"
